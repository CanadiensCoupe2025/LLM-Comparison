{
  "uid": "llm-quality-triage",
  "title": "LLM Quality Triage",
  "tags": ["llmeter", "triage", "quality"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": { "from": "now-30d", "to": "now" },
  "timezone": "browser",
  "refresh": "",
  "templating": {
    "list": [
      {
        "name": "run",
        "label": "Run (test)",
        "type": "query",
        "datasource": { "type": "postgres", "uid": "llmeter_postgres" },
        "query": "SELECT id AS __value, dataset || ' #' || id AS __text FROM runs ORDER BY id DESC",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "sort": 0
      },
      {
        "name": "max_score",
        "label": "Note max affichée",
        "type": "custom",
        "query": "0.5,1.5,3,4.5,4.9",
        "current": { "text": "4.9 (tout sauf 5)", "value": "4.9" },
        "options": [
          { "text": "0.5 (refus / échecs)", "value": "0.5", "selected": false },
          { "text": "1.5", "value": "1.5", "selected": false },
          { "text": "3", "value": "3", "selected": false },
          { "text": "4.5", "value": "4.5", "selected": false },
          { "text": "4.9 (tout sauf 5)", "value": "4.9", "selected": true }
        ],
        "includeAll": false,
        "multi": false
      },
      {
        "name": "model",
        "label": "Modèle",
        "type": "query",
        "datasource": { "type": "postgres", "uid": "llmeter_postgres" },
        "query": "SELECT DISTINCT model FROM result_review WHERE run_id = $run ORDER BY 1",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "barchart",
      "title": "Type d'échec par modèle (notes <= $max_score)",
      "description": "Répartition des réponses non parfaites par cause dominante (failure_type heuristique, vue result_review). Filtré par les variables Note max / Modèle.",
      "datasource": { "type": "postgres", "uid": "llmeter_postgres" },
      "gridPos": { "h": 9, "w": 14, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "datasource": { "type": "postgres", "uid": "llmeter_postgres" },
          "rawSql": "SELECT failure_type, count(*) FILTER (WHERE model = 'claude-haiku-4-5') AS \"claude-haiku-4-5\", count(*) FILTER (WHERE model = 'claude-sonnet-4-6') AS \"claude-sonnet-4-6\", count(*) FILTER (WHERE model = 'gpt-5') AS \"gpt-5\" FROM result_review WHERE run_id = $run AND (judge_score <= $max_score OR judge_score IS NULL) AND model IN ($model) GROUP BY failure_type ORDER BY 1;"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 80, "axisLabel": "nombre de réponses", "gradientMode": "none" }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "xField": "failure_type",
        "showValue": "always",
        "stacking": "normal",
        "groupWidth": 0.7,
        "barWidth": 0.9,
        "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom", "calcs": [] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 2,
      "type": "table",
      "title": "Prompts les plus problématiques",
      "description": "Cas (case_id) avec le plus de réponses non parfaites, et leur note moyenne. Les cas où plusieurs modèles échouent sont les plus instructifs.",
      "datasource": { "type": "postgres", "uid": "llmeter_postgres" },
      "gridPos": { "h": 9, "w": 10, "x": 14, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "datasource": { "type": "postgres", "uid": "llmeter_postgres" },
          "rawSql": "SELECT case_id, left(max(question), 70) AS question, count(*) AS n_sous_5, round(avg(judge_score), 2) AS note_moy FROM result_review WHERE run_id = $run AND (judge_score <= $max_score OR judge_score IS NULL) AND model IN ($model) GROUP BY case_id ORDER BY n_sous_5 DESC, note_moy ASC NULLS FIRST LIMIT 25;"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "align": "left", "filterable": true } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "case_id" }, "properties": [{ "id": "custom.width", "value": 150 }] },
          { "matcher": { "id": "byName", "options": "n_sous_5" }, "properties": [{ "id": "custom.width", "value": 90 }] },
          {
            "matcher": { "id": "byName", "options": "note_moy" },
            "properties": [
              { "id": "custom.width", "value": 90 },
              { "id": "decimals", "value": 2 },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
              { "id": "min", "value": 0 }, { "id": "max", "value": 5 },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "value": null, "color": "red" }, { "value": 2.5, "color": "orange" }, { "value": 4, "color": "green" } ] } }
            ]
          }
        ]
      },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "n_sous_5", "desc": true }] }
    },
    {
      "id": 3,
      "type": "table",
      "title": "Détail — réponses notées <= $max_score (triées par note croissante)",
      "description": "Chaque réponse non parfaite : note, type d'échec déduit, question, réponse complète et justification du juge. Trier/filtrer par colonne. Source: vue result_review.",
      "datasource": { "type": "postgres", "uid": "llmeter_postgres" },
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 9 },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "datasource": { "type": "postgres", "uid": "llmeter_postgres" },
          "rawSql": "SELECT judge_score AS note, model, failure_type AS type_echec, case_id, question, response, judge_reasoning FROM result_review WHERE run_id = $run AND (judge_score <= $max_score OR judge_score IS NULL) AND model IN ($model) ORDER BY judge_score ASC NULLS FIRST, model LIMIT 500;"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "left", "cellOptions": { "type": "auto", "wrapText": true }, "inspect": true, "filterable": true, "minWidth": 80 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "note" },
            "properties": [
              { "id": "custom.width", "value": 70 },
              { "id": "min", "value": 0 }, { "id": "max", "value": 5 },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "value": null, "color": "red" }, { "value": 2.5, "color": "orange" }, { "value": 4, "color": "green" } ] } }
            ]
          },
          { "matcher": { "id": "byName", "options": "model" }, "properties": [{ "id": "custom.width", "value": 150 }] },
          { "matcher": { "id": "byName", "options": "type_echec" }, "properties": [{ "id": "custom.width", "value": 170 }] },
          { "matcher": { "id": "byName", "options": "case_id" }, "properties": [{ "id": "custom.width", "value": 150 }] },
          { "matcher": { "id": "byName", "options": "question" }, "properties": [{ "id": "custom.width", "value": 320 }] },
          { "matcher": { "id": "byName", "options": "response" }, "properties": [{ "id": "custom.width", "value": 430 }] },
          { "matcher": { "id": "byName", "options": "judge_reasoning" }, "properties": [{ "id": "custom.width", "value": 430 }] }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "md",
        "footer": { "show": false, "reducer": ["sum"], "countRows": false, "fields": "" },
        "sortBy": [{ "displayName": "note", "desc": false }]
      }
    }
  ]
}
