{
  "uid": "llm-model-comparison",
  "title": "LLM Model Comparison",
  "tags": ["llmeter", "scrum-30"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": { "from": "now-30d", "to": "now" },
  "timezone": "browser",
  "refresh": "",
  "panels": [
    {
      "id": 1,
      "type": "barchart",
      "title": "Avg latency per model (ms)",
      "description": "Mean response latency per model across all evaluations. Source: model_metrics.",
      "datasource": { "type": "postgres", "uid": "llmeter_postgres" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "datasource": { "type": "postgres", "uid": "llmeter_postgres" },
          "rawSql": "SELECT model, avg_latency_ms\nFROM model_metrics\nORDER BY avg_latency_ms;"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 80, "axisLabel": "avg latency (ms)", "gradientMode": "none" }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "xField": "model",
        "colorByField": "model",
        "showValue": "always",
        "stacking": "none",
        "groupWidth": 0.7,
        "barWidth": 0.9,
        "legend": { "showLegend": false, "displayMode": "list", "placement": "right", "calcs": [] },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "id": 2,
      "type": "barchart",
      "title": "Avg judge score per model (0-5)",
      "description": "Mean judge quality score per model (judged results only). Source: model_metrics.",
      "datasource": { "type": "postgres", "uid": "llmeter_postgres" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "datasource": { "type": "postgres", "uid": "llmeter_postgres" },
          "rawSql": "SELECT model, avg_judge_score\nFROM model_metrics\nWHERE avg_judge_score IS NOT NULL\nORDER BY avg_judge_score DESC;"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 5,
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 80, "axisLabel": "avg judge score (0-5)", "gradientMode": "none" }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "xField": "model",
        "colorByField": "model",
        "showValue": "always",
        "stacking": "none",
        "groupWidth": 0.7,
        "barWidth": 0.9,
        "legend": { "showLegend": false, "displayMode": "list", "placement": "right", "calcs": [] },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "id": 3,
      "type": "barchart",
      "title": "Cumulative cost per model (USD)",
      "description": "Total cost per model across all evaluations. Source: model_metrics.",
      "datasource": { "type": "postgres", "uid": "llmeter_postgres" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "datasource": { "type": "postgres", "uid": "llmeter_postgres" },
          "rawSql": "SELECT model, total_cost\nFROM model_metrics\nORDER BY total_cost DESC;"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 5,
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 80, "axisLabel": "total cost (USD)", "gradientMode": "none" }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "xField": "model",
        "colorByField": "model",
        "showValue": "always",
        "stacking": "none",
        "groupWidth": 0.7,
        "barWidth": 0.9,
        "legend": { "showLegend": false, "displayMode": "list", "placement": "right", "calcs": [] },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "id": 4,
      "type": "table",
      "title": "Judge score mean ± stddev per model",
      "description": "Quality with run-to-run spread from repeated sampling. mean = avg_judge_score (the N-sample mean the regression alert uses); stddev = STDDEV_SAMP over samples (NULL/blank when n_results < 2). Source: model_metrics.",
      "datasource": { "type": "postgres", "uid": "llmeter_postgres" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "datasource": { "type": "postgres", "uid": "llmeter_postgres" },
          "rawSql": "SELECT model, avg_judge_score AS mean_score, stddev_judge_score AS stddev_score, n_cases, n_results AS n_samples\nFROM model_metrics\nWHERE avg_judge_score IS NOT NULL\nORDER BY avg_judge_score DESC;"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "mean_score" },
            "properties": [
              { "id": "decimals", "value": 1 },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 3.5 } ] } },
              { "id": "custom.displayMode", "value": "color-text" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "stddev_score" },
            "properties": [ { "id": "decimals", "value": 2 } ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [ { "displayName": "mean_score", "desc": true } ]
      }
    },
    {
      "id": 5,
      "type": "table",
      "title": "Detailed results / logs (question, response, judge)",
      "description": "One row per result: the question asked, the full model response, and the judge's score + reasoning. Source: results joined to models. No prompt_style filter, so every dataset shows here.",
      "datasource": { "type": "postgres", "uid": "llmeter_postgres" },
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 32 },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "datasource": { "type": "postgres", "uid": "llmeter_postgres" },
          "rawSql": "SELECT\n  res.created_at      AS \"created_at\",\n  res.case_id         AS \"case_id\",\n  m.name              AS \"model\",\n  res.question        AS \"question\",\n  res.response        AS \"response\",\n  res.judge_score     AS \"judge_score\",\n  res.judge_reasoning AS \"judge_reasoning\"\nFROM results res\nJOIN models m ON m.id = res.model_id\nORDER BY res.created_at DESC\nLIMIT 500;"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "cellOptions": { "type": "auto", "wrapText": true },
            "inspect": true,
            "filterable": true,
            "minWidth": 80
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "created_at" },
            "properties": [
              { "id": "custom.width", "value": 160 },
              { "id": "unit", "value": "time:YYYY-MM-DD HH:mm:ss" }
            ]
          },
          { "matcher": { "id": "byName", "options": "case_id" }, "properties": [{ "id": "custom.width", "value": 170 }] },
          { "matcher": { "id": "byName", "options": "model" }, "properties": [{ "id": "custom.width", "value": 150 }] },
          { "matcher": { "id": "byName", "options": "question" }, "properties": [{ "id": "custom.width", "value": 340 }] },
          { "matcher": { "id": "byName", "options": "response" }, "properties": [{ "id": "custom.width", "value": 460 }] },
          {
            "matcher": { "id": "byName", "options": "judge_score" },
            "properties": [
              { "id": "custom.width", "value": 110 },
              { "id": "min", "value": 0 },
              { "id": "max", "value": 5 },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "value": null, "color": "red" },
                    { "value": 2.5, "color": "orange" },
                    { "value": 4, "color": "green" }
                  ]
                }
              }
            ]
          },
          { "matcher": { "id": "byName", "options": "judge_reasoning" }, "properties": [{ "id": "custom.width", "value": 460 }] }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "md",
        "footer": { "show": false, "reducer": ["sum"], "countRows": false, "fields": "" },
        "sortBy": [{ "displayName": "created_at", "desc": true }]
      }
    }
  ]
}
